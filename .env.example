DATABASE_URL=postgresql://envoyer:envoyer@localhost:5432/envoyer
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
ENCRYPTION_KEY=
CRON_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
GOOGLE_AI_KEY=
MISTRAL_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Transactional email via Cloudflare Email Sending. The EMAIL_FROM domain must
# be onboarded first: npx wrangler email sending enable <domain>
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
EMAIL_FROM=Envoy <noreply@byenvoy.com>

# PostHog (product analytics, session replay, error tracking)
# Get the project token from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Set to false for self-hosted (disables billing and Stripe)
ENVOY_CLOUD=false

# Optional: cron schedule for knowledge base recrawl (default: every 6 hours)
RECRAWL_SCHEDULE=0 */6 * * *

# Optional: how far back the FIRST poll on a new email connection looks for
# messages, in minutes. Default 4320 (3 days). Set lower in dev (e.g. 30) so
# test inboxes don't ingest weeks of marketing email on first connect.
EMAIL_INITIAL_LOOKBACK_MINUTES=4320
